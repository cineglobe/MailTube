# Created automatically by `mailtube setup`. Do not commit the populated file.
MAILTUBE_IMAGE=ghcr.io/cineglobe/mailtube:latest
MAILTUBE_DEPLOYMENT_MODE=localhost
MAILTUBE_BIND_ADDRESS=127.0.0.1
MAILTUBE_HTTP_PORT=8080
MAILTUBE_HOST=0.0.0.0
MAILTUBE_PORT=8080
MAILTUBE_PUBLIC_URL=http://127.0.0.1:8080
MAILTUBE_ALLOWED_HOSTS=localhost,127.0.0.1,mailtube

MAILTUBE_ADMIN_USERNAME=admin
MAILTUBE_ADMIN_PASSWORD_HASH=
MAILTUBE_SESSION_SECRET=
MAILTUBE_SECURE_COOKIES=false
MAILTUBE_INSTANCE_ID=replace-with-a-random-instance-id

MAILTUBE_MAX_URLS_PER_BATCH=5
MAILTUBE_MAX_CONCURRENT_JOBS=1
MAILTUBE_MAX_DURATION_SECONDS=7200
MAILTUBE_MAX_FILE_MB=1024
MAILTUBE_RETENTION_HOURS=24
MAILTUBE_MAX_EMAIL_REQUESTS_PER_HOUR=10
MAILTUBE_COOKIES_SOURCE=./docker/empty-cookies.txt
MAILTUBE_COOKIES_FILE=

MAILTUBE_EMAIL_ENABLED=false
MAILTUBE_IMAP_HOST=imap.gmail.com
MAILTUBE_IMAP_PORT=993
MAILTUBE_IMAP_FOLDER=INBOX
MAILTUBE_IMAP_USERNAME=
MAILTUBE_IMAP_PASSWORD=
MAILTUBE_SMTP_HOST=smtp.gmail.com
MAILTUBE_SMTP_PORT=587
MAILTUBE_SMTP_SECURITY=starttls
MAILTUBE_SMTP_USERNAME=
MAILTUBE_SMTP_PASSWORD=
MAILTUBE_SMTP_FROM=
MAILTUBE_SENDER_POLICY=allowlist
MAILTUBE_SENDER_ALLOWLIST=
MAILTUBE_DELIVERY_MODE=links

MAILTUBE_STORAGE_BACKEND=local
MAILTUBE_S3_ENDPOINT=
MAILTUBE_S3_REGION=auto
MAILTUBE_S3_BUCKET=
MAILTUBE_S3_ACCESS_KEY_ID=
MAILTUBE_S3_SECRET_ACCESS_KEY=
MAILTUBE_S3_FORCE_PATH_STYLE=false
MAILTUBE_POT_PROVIDER_URL=
MAILTUBE_UPDATE_CHANNEL=stable
COMPOSE_PROFILES=
